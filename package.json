{
  "name": "@blaze-money/cli",
  "version": "0.1.0",
  "description": "Blaze payments SDK, CLI, and MCP server — payments infrastructure for modern businesses",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/blaze-xyz/cli.git"
  },
  "homepage": "https://github.com/blaze-xyz/cli#readme",
  "bugs": "https://github.com/blaze-xyz/cli/issues",
  "keywords": [
    "blaze",
    "payments",
    "cli",
    "sdk",
    "mcp",
    "fintech",
    "cross-border",
    "transfers",
    "api"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "default": "./dist/mcp/server.js"
    }
  },
  "bin": {
    "blaze": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=8192' tsup src/cli/index.ts src/index.ts src/mcp/server.ts --format cjs --dts",
    "dev": "tsup src/cli/index.ts src/index.ts src/mcp/server.ts --format cjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.ts",
    "test:e2e": "jest --config jest.e2e.config.ts",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "test:integration": "jest --config jest.e2e.config.ts --runInBand",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.9.2"
}
